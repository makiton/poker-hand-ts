{
  "name": "poker-hand-ts",
  "version": "0.1.0",
  "description": "Cactus Kev's poker hand evaluator in TypeScript",
  "license": "MIT",
  "keywords": ["poker", "hand-evaluator", "cactus-kev", "cards", "typescript"],
  "repository": {
    "type": "git",
    "url": "https://github.com/makiton/poker-hand-ts.git"
  },
  "bugs": {
    "url": "https://github.com/makiton/poker-hand-ts/issues"
  },
  "homepage": "https://github.com/makiton/poker-hand-ts#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "generate": "npx tsx scripts/generate-tables.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
